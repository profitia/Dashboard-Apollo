# AI Outreach System — konfiguracja LLM
# Skopiuj ten plik jako .env i uzupełnij wartości.

# Provider: "openai" lub "github"
# github = GitHub Models (używa GITHUB_TOKEN, modele dostępne w ramach subskrypcji Copilot)
# openai = bezpośrednio OpenAI API (wymaga OPENAI_API_KEY)
LLM_PROVIDER=github

# Model (np. gpt-4o-mini, gpt-4o, gpt-4.1-mini)
LLM_MODEL=gpt-4o-mini

# --- GitHub Models (provider=github) ---
# Personal Access Token z github.com/settings/tokens
# Wymagane uprawnienia: nie potrzeba dodatkowych scope'ów
GITHUB_TOKEN=

# --- OpenAI (provider=openai) ---
# Klucz API OpenAI — nie commituj prawdziwego klucza!
OPENAI_API_KEY=
