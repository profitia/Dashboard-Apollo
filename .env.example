# AI Outreach System — konfiguracja LLM
# Skopiuj ten plik jako .env i uzupełnij wartości.

# Provider: "openai" lub "github"
# github = GitHub Models (używa GITHUB_TOKEN, modele dostępne w ramach subskrypcji Copilot)
# openai = bezpośrednio OpenAI API (wymaga OPENAI_API_KEY)
LLM_PROVIDER=openai

# --- Modele OpenAI (globalna konfiguracja) ---
# Primary model — finalne maile, personalizacja, rewrite, trudne decyzje copywriterskie
OPENAI_PRIMARY_MODEL=gpt-5.4
# Fallback model — szkice, warianty, mniej krytyczne generowanie, fallback przy błędach primary
OPENAI_FALLBACK_MODEL=gpt-5.4-mini
# Cheap model — klasyfikacja ICP, scoring leadów, walidacja CTA, sprawdzanie formatu
OPENAI_CHEAP_MODEL=gpt-5.4-nano
# Reasoning effort (low/medium/high) — dla modeli wspierających reasoning
OPENAI_REASONING_EFFORT=medium

# --- Legacy (backward-compatible) ---
# LLM_MODEL jest nadal obsługiwany, ale OPENAI_PRIMARY_MODEL ma priorytet
LLM_MODEL=gpt-5.4

# --- GitHub Models (provider=github) ---
# Personal Access Token z github.com/settings/tokens
# Wymagane uprawnienia: nie potrzeba dodatkowych scope'ów
GITHUB_TOKEN=

# --- OpenAI (provider=openai) ---
# Klucz API OpenAI — nie commituj prawdziwego klucza!
OPENAI_API_KEY=

# ---- Apollo API ----
# Master API key z Apollo (Settings > Integrations > API)
APOLLO_API_KEY=

# ---- PostgreSQL / Neon ----
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require
DATABASE_URL=
