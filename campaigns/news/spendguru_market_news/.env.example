# ============================================================
# SpendGuru Market News — News-Triggered Outreach Pipeline
# Skopiuj ten plik do Integracje/.env i uzupełnij wszystkie wartości
# ============================================================

# --- LLM (GitHub Models lub OpenAI) ---
# GitHub fine-grained PAT z permission "models" (zalecane)
GITHUB_TOKEN=your_github_token_here

# Alternatywnie: klucz OpenAI bezpośrednio
# OPENAI_API_KEY=sk-...

# Modele (opcjonalne — zostaną użyte domyślne jeśli brak)
# OPENAI_PRIMARY_MODEL=gpt-4.1-mini
# OPENAI_FALLBACK_MODEL=gpt-4.1-mini
# OPENAI_CHEAP_MODEL=gpt-4.1-nano

# --- Apollo ---
APOLLO_API_KEY=your_apollo_api_key_here

# ID kont mailowych do wysyłki w Apollo (round-robin)
# Znajdź w Apollo: Settings > Email Accounts > skopiuj ID
APOLLO_MAILBOX_IDS=mailbox_id_1,mailbox_id_2

# --- Office365 (email notifications — opcjonalne) ---
# Wymagane tylko jeśli notification_channels zawiera "email"
AZURE_CLIENT_ID=your_azure_client_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_SECRET=your_azure_client_secret
NOTIFICATION_FROM_EMAIL=tomasz.uscinski@profitia.pl
NOTIFICATION_TO_EMAIL=tomasz.uscinski@profitia.pl

# --- wiadomoscihandlowe.pl (opcjonalne — paywall: logged_in) ---
# Wymagane tylko jeśli sources.yaml ma paywall.mode: logged_in
# WH_USERNAME=twoj_login@example.com
# WH_PASSWORD=twoje_haslo

# --- Webhook (opcjonalne) ---
# Wymagane tylko jeśli notification_channels zawiera "webhook"
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
