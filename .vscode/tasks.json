      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "News: Run Daily (live)",
      "type": "shell",
      "command": "python src/news/orchestrator.py run-daily --verbose",
      "group": "build",
